# Copy this file to secrets.yaml and fill in your own values.
# secrets.yaml is gitignored so your credentials are never committed.

wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"

# Fallback hotspot password (used if Wi-Fi fails)
ap_password: "changeme12"

# Generate with:  openssl rand -base64 32
api_encryption_key: "REPLACE_WITH_32_BYTE_BASE64_KEY"

# OTA update password
ota_password: "REPLACE_WITH_OTA_PASSWORD"
